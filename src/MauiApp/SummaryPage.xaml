<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RagChatApp.SummaryPage"
             Title="Summary"
             BackgroundColor="{AppThemeBinding Light=#F5F3FB, Dark=#141414}">

    <Grid RowDefinitions="Auto,*" Padding="16" RowSpacing="16">

        <VerticalStackLayout x:Name="LoadingSection"
                             Grid.Row="0"
                             Spacing="10"
                             Padding="0,24,0,0"
                             HorizontalOptions="Center">
            <ActivityIndicator x:Name="LoadingIndicator"
                                IsRunning="True"
                                HorizontalOptions="Center" />
            <Label x:Name="LoadingStatusLabel"
                   Text="Generating summary…"
                   FontSize="13"
                   Opacity="0.6"
                   HorizontalOptions="Center" />
        </VerticalStackLayout>

        <ScrollView Grid.Row="1">
            <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#1f1f1f}"
                    StrokeShape="RoundRectangle 16"
                    Stroke="{AppThemeBinding Light=#E1E1E1, Dark=#404040}"
                    Padding="20">
                <VerticalStackLayout Spacing="8">
                    <Label Text="📄 Document Summary"
                           FontSize="17"
                           FontAttributes="Bold" />
                    <Label x:Name="SummaryLabel"
                           Text=""
                           FontSize="15"
                           LineHeight="1.3" />
                </VerticalStackLayout>
            </Border>
        </ScrollView>

    </Grid>

</ContentPage>
