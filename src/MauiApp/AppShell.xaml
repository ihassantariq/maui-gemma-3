<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="RagChatApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:RagChatApp"
    Title="RAG Chat">

    <!-- Initial, non-tabbed route: model setup + PDF picker -->
    <ShellContent
        x:Name="SetupShellContent"
        Title="Setup"
        Route="setup" />

    <!-- Shown only after a PDF is successfully indexed (navigated to via "//main") -->
    <TabBar Route="main">
        <Tab Title="📄 Summary" Route="summary">
            <ShellContent x:Name="SummaryShellContent" Route="summary" />
        </Tab>
        <Tab Title="💬 Ask AI" Route="chat">
            <ShellContent x:Name="ChatShellContent" Route="chat" />
        </Tab>
    </TabBar>

</Shell>
