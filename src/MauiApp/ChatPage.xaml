<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RagChatApp.ChatPage"
             Title="Ask AI"
             BackgroundColor="{AppThemeBinding Light=#F5F3FB, Dark=#141414}">

    <Grid RowDefinitions="*,Auto"
          HorizontalOptions="Fill"
          VerticalOptions="Fill">

        <CollectionView x:Name="MessagesView"
                        ItemsSource="{Binding Messages}"
                        Grid.Row="0"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill"
                        Margin="0,8,0,0">
            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="8"
                                     Padding="32">
                    <Label Text="💬"
                           FontSize="40"
                           HorizontalOptions="Center" />
                    <Label Text="Ask anything about your document"
                           FontSize="16"
                           Opacity="0.6"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="12,6" ColumnDefinitions="*,Auto">
                        <Border BackgroundColor="{Binding BubbleColor}"
                                Stroke="Transparent"
                                Padding="14,10"
                                HorizontalOptions="{Binding BubbleAlign}"
                                Grid.Column="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="{Binding BubbleCorners}" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Opacity="0.08" Radius="6" Offset="0,2" />
                            </Border.Shadow>
                            <Label FormattedText="{Binding FormattedText}"
                                   FontSize="15"
                                   LineBreakMode="WordWrap" />
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <VerticalStackLayout Grid.Row="1" HorizontalOptions="Fill">
            <BoxView HeightRequest="1"
                     Color="{AppThemeBinding Light=#E1E1E1, Dark=#404040}"
                     HorizontalOptions="Fill" />
            <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#1f1f1f}"
                    StrokeShape="RoundRectangle 0"
                    Stroke="Transparent"
                    HorizontalOptions="Fill"
                    Padding="12,10">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" HorizontalOptions="Fill">
                    <Border Grid.Column="0"
                            BackgroundColor="{AppThemeBinding Light=#F0EDF9, Dark=#2a2a2a}"
                            StrokeShape="RoundRectangle 22"
                            Stroke="Transparent"
                            HorizontalOptions="Fill"
                            Padding="16,2">
                        <Entry x:Name="QuestionEntry"
                               Placeholder="Ask a question…"
                               ReturnCommand="{Binding AskCommand}"
                               BackgroundColor="Transparent" />
                    </Border>
                    <Button x:Name="AskButton"
                            Text="➤"
                            FontSize="18"
                            Clicked="OnAskClicked"
                            CornerRadius="22"
                            WidthRequest="44"
                            HeightRequest="44"
                            Padding="0"
                            Grid.Column="1" />
                </Grid>
            </Border>
        </VerticalStackLayout>
    </Grid>

</ContentPage>
